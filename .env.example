# ====================
# 机器人摄像头
# ====================
ROBOT_RTSP_URL=rtsp://<robot-ip>:8554/video1

# ====================
# MQTT 云端指令通道（智慧工地平台）
# ====================
MQTT_BROKER=<mqtt-broker-ip>
MQTT_PORT=1883
MQTT_CLIENT_ID=<mqtt-client-id>
MQTT_USER=<mqtt-username>
MQTT_PW=<mqtt-password>
MQTT_SUB_TOPIC=<mqtt-subscribe-topic>

# ====================
# GB/T 28181 上级平台 SIP（视频主站）
# ====================
GB28181_SIP_SERVER_HOST=<sip-server-ip>
GB28181_SIP_SERVER_PORT=5788
GB28181_SIP_SERVER_ID=<sip-server-id>
GB28181_SIP_DOMAIN=<sip-server-domain>
GB28181_SIP_USERNAME=<device-id>
GB28181_SIP_AUTH_ID=<auth-id>
GB28181_SIP_PASSWORD=<sip-password>
GB28181_CHANNEL_ID=<channel-id>
GB28181_LOCAL_SIP_IP=<local-ip>
GB28181_LOCAL_SIP_PORT=15060

# 调试模式（可选，打印原始SIP报文）
# GB28181_DEBUG=1
